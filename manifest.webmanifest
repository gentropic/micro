{
  "name": "GCU Micro",
  "short_name": "Micro",
  "id": "/micro/",
  "description": "Open massive spatial-element files — LiDAR point clouds (.las, .ply, .xyz) and block models (.csv, Datamine .dm) — and orbit, filter, section, pick, and measure against the source. Streaming, no import step, offline.",
